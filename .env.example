.env example for local development (do NOT commit real secrets)

# Supabase - used by edge functions
PROJECT_URL=https://your-project.supabase.co
SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: an application JWT secret if you plan to mint your own session tokens
AUTH_JWT_SECRET=replace-with-a-very-strong-secret

# Frontend: URL where Supabase functions are hosted (optional)
VITE_FUNCTIONS_URL=https://your-project.functions.supabase.co

